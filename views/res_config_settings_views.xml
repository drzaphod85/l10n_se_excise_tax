<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Adds a "Swedish Excise Tax" block to the Accounting / Invoicing
        settings page with the two display toggles: one for the excise
        row itself, one for VAT (with a compliance warning).

        The block is anchored inside the standard Accounting/Invoicing
        <app> container using `position="inside"`, which is stable
        across Odoo 17, 18 and 19 even when individual sub-blocks are
        renamed or reordered by downstream localisations.
    -->
    <record id="res_config_settings_view_form_l10n_se_excise_tax"
            model="ir.ui.view">
        <field name="name">res.config.settings.view.form.l10n_se_excise_tax.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="Swedish Excise Tax"
                       id="l10n_se_excise_tax_block"
                       name="l10n_se_excise_tax_block">

                    <setting id="l10n_se_excise_show_row_setting"
                             title="Show Excise Tax as Separate Row"
                             help="Whether the Swedish excise tax
                                   appears as its own row between
                                   Untaxed Amount and VAT on
                                   quotations, sales orders, invoices
                                   and their PDF / portal renderings.
                                   When disabled, the excise amount is
                                   folded into Untaxed Amount (VAT
                                   base and total are unchanged).">
                        <field name="excise_show_as_separate_row"/>
                    </setting>

                    <setting id="l10n_se_hide_vat_column_setting"
                             title="Hide VAT Column on Documents"
                             help="Hide the Moms / VAT / Taxes
                                   column from the line table on
                                   quotation PDFs, order PDFs,
                                   invoice PDFs and the customer
                                   portal. The column is still
                                   available on the internal form
                                   view (toggle it via the column
                                   picker if you don't want to see
                                   it there either).">
                        <field name="hide_vat_column_on_documents"/>
                        <div class="text-muted mt8"
                             invisible="not hide_vat_column_on_documents">
                            <small>
                                <i class="fa fa-info-circle"/>
                                Only the per-line Moms column is
                                hidden. The VAT amount and rate
                                still appear in the totals block on
                                every document, so the Swedish
                                invoice disclosure requirement is
                                preserved.
                            </small>
                        </div>
                    </setting>

                </block>
            </xpath>
        </field>
    </record>

</odoo>
