<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_excise_inherit" model="ir.ui.view">
        <field name="name">account.move.form.excise.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="after">
                <field name="excise_weight" optional="hide"/>
                <field name="excise_reduction_ratio" optional="hide" widget="percentage"/>
            </xpath>
        </field>
    </record>
</odoo>