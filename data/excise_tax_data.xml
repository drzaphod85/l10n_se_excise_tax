        <!--
            ============================================================
            Nikotinskatt — Excise Tax Types (2026 rates per Skatteverket)
            ============================================================
            * E-vätska (regular)              2 020,00 SEK/L
            * E-vätska (högkoncentrerad)      4 040,00 SEK/L
            * Övriga nikotinhaltiga produkter   202,00 SEK/kg
            "Högkoncentrerad" follows the threshold defined in
            Lag (2018:696) — typically nicotine concentration above the
            limit set for general retail. The accountant assigns the
            relevant tax type per product based on the product's
            classification.

            No max_limit on these (no per-unit cap in the nicotine
            statute), and no reduction (Kemikalieskatt's 50 % / 90 %
            rule doesn't apply here).
        -->
        <record id="excise_type_nicotine_eliquid" model="excise.tax.type">
