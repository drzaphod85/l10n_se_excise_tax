        <!--
            ============================================================
            Excise Tax Types (rate + cap + unit_basis)
            ============================================================
            Kemikalieskatt rates updated to the 2026-01-01 Skatteverket
            values:
              * Electronics (High Rate): 180.71 SEK/kg (was 114.00)
              * Major Appliances (Low Rate): 12.42 SEK/kg (was 11.00)
              * Max cap per unit: 552.27 SEK (was 562.00)
            See migrations/19.0.2.0.0/post-migration.py for the
            equivalent SQL update on already-installed databases (the
            data file is noupdate=1).
        -->
        <record id="excise_type_electronics" model="excise.tax.type">
            <field name="name">Electronics (High Rate)</field>
            <field name="country_id" ref="base.se"/>
            <field name="unit_basis">kg</field>
            <field name="tax_rate">180.71</field>
            <field name="max_limit">552.27</field>
            <field name="has_reduction_levels" eval="True"/>
        </record>

        <record id="excise_type_major_appliances" model="excise.tax.type">
            <field name="name">Major Appliances (Low Rate)</field>
