        <!--
            Dedicated tax group so Odoo's tax_totals widget renders the
            excise tax as its own subtotal row before VAT.
        -->
        <record id="tax_group_excise" model="account.tax.group">
            <field name="name">Swedish Excise Tax</field>
            <field name="sequence">5</field>
        </record>

        <!--
            ============================================================
            Skatteverket reporting tags (account.account.tag)
            ============================================================
            Used by the punktskattedeklaration aggregation. We follow
            Odoo's +/- convention: the same logical tag exists in two
            variants so refunds (credit notes) reverse the sign.
        -->
        <record id="tag_chem_tax_base_invoice" model="account.account.tag">
            <field name="name">+Kemikalieskatt - Underlag</field>
            <field name="applicability">taxes</field>
            <field name="country_id" ref="base.se"/>
        </record>
        <record id="tag_chem_tax_tax_invoice" model="account.account.tag">
            <field name="name">+Kemikalieskatt - Skatt att betala</field>
            <field name="applicability">taxes</field>
            <field name="country_id" ref="base.se"/>
        </record>
        <record id="tag_chem_tax_base_refund" model="account.account.tag">
            <field name="name">-Kemikalieskatt - Underlag</field>
            <field name="applicability">taxes</field>
            <field name="country_id" ref="base.se"/>
        </record>
        <record id="tag_chem_tax_tax_refund" model="account.account.tag">
            <field name="name">-Kemikalieskatt - Skatt att betala</field>
            <field name="applicability">taxes</field>
